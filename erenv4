                KorbloxConn:Disconnect()
            end
        end)
    else
        if KorbloxConn then KorbloxConn:Disconnect(); KorbloxConn = nil end
        rLeg.Transparency = 0; rLeg.CanCollide = true
        local kp = char:FindFirstChild("KorbloxLeg")
        if kp then kp:Destroy() end
    end
end)

