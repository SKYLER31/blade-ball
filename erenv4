--  TWEEN HELPERS
-- ─────────────────────────────────────────────
local function tween(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quint
    dir   = dir   or Enum.EasingDirection.Out
    TweenService:Create(obj, TweenInfo.new(t or 0.25, style, dir), props):Play()
end

local function flash(label, col, t)
    local orig = label.TextColor3
    tween(label, {TextColor3 = col}, 0.1)
    task.delay(t or 0.3, function() tween(label, {TextColor3 = orig}, 0.2) end)
end

