            tween(pill,{BackgroundColor3=C.TOGGLE_OFF},0.2)
            tween(knob,{Position=UDim2.new(0,3,0.5,-9)},0.2,Enum.EasingStyle.Back)
            tween(s,{Color=C.STROKE,Transparency=0.6},0.2)
        end
        if callback then callback(v) end
    end

    local btn = Instance.new("TextButton", card)
    btn.Size            = UDim2.new(1,0,1,0)
    btn.BackgroundTransparency = 1
    btn.Text            = ""
    btn.AutoButtonColor = false
    btn.MouseButton1Click:Connect(function() setState(not state) end)
    btn.MouseEnter:Connect(function() tween(card,{BackgroundColor3=Color3.fromRGB(32,24,60)},0.1) end)
    btn.MouseLeave:Connect(function() tween(card,{BackgroundColor3=C.CARD},0.1) end)

    setState(state)
    return setState
end

