local tabList   = {}
local pageList  = {}
local activeTab = nil

local function CreateTab(name, icon)
    local btn = Instance.new("TextButton", Sidebar)
    btn.Size            = UDim2.new(1,-12,0,36)
    btn.Position        = UDim2.new(0,6,0,0)
    btn.BackgroundColor3= C.CARD
    btn.Text            = (icon or "") .. "  " .. name
    btn.Font            = Enum.Font.GothamSemibold
    btn.TextSize        = 12
    btn.TextColor3      = C.TEXT_DIM
    btn.AutoButtonColor = false
    btn.TextXAlignment  = Enum.TextXAlignment.Left
    btn.LayoutOrder     = #tabList + 1
    local btnCorner     = Instance.new("UICorner",btn)
    btnCorner.CornerRadius = UDim.new(0,8)
    Instance.new("UIPadding",btn).PaddingLeft = UDim.new(0,10)

    local indicator = Instance.new("Frame", btn)
    indicator.Size   = UDim2.new(0,3,0.7,0)
    indicator.Position = UDim2.new(0,-6,0.15,0)
    indicator.BackgroundColor3 = C.ACCENT
    indicator.BorderSizePixel  = 0
    indicator.BackgroundTransparency = 1
    Instance.new("UICorner",indicator).CornerRadius = UDim.new(1,0)

    local page = Instance.new("ScrollingFrame", Pages)
    page.Size              = UDim2.new(1,0,1,0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel   = 0
    page.ScrollBarThickness= 3
    page.ScrollBarImageColor3 = C.ACCENT
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.CanvasSize        = UDim2.new(0,0,0,0)
    page.Visible           = false

    local pageLayout = Instance.new("UIListLayout", page)
    pageLayout.Padding     = UDim.new(0,8)
    pageLayout.SortOrder   = Enum.SortOrder.LayoutOrder
    Instance.new("UIPadding",page).PaddingTop = UDim.new(0,8)

    local idx = #tabList + 1
    tabList[idx]  = btn
    pageList[idx] = page

    btn.MouseButton1Click:Connect(function()
        if activeTab == idx then return end
        if activeTab then
            local ob = tabList[activeTab]
            tween(ob,{BackgroundColor3=C.CARD,TextColor3=C.TEXT_DIM},0.2)
            ob:FindFirstChild("Frame").BackgroundTransparency = 1
            pageList[activeTab].Visible = false
        end
        activeTab = idx
        tween(btn,{BackgroundColor3=C.ACCENT_DIM,TextColor3=C.TEXT},0.2)
        indicator.BackgroundTransparency = 0
        page.Visible = true
    end)

    btn.MouseEnter:Connect(function()
        if activeTab ~= idx then tween(btn,{BackgroundColor3=C.CARD},0.1) end
        tween(btn,{TextColor3=C.TEXT},0.1)
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= idx then
            tween(btn,{BackgroundColor3=C.CARD,TextColor3=C.TEXT_DIM},0.1)
        end
    end)

    return page
end

