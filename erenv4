local function randomString(len)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local str = ""
    for i = 1, len or 16 do
        local r = math.random(1, #chars)
        str = str .. chars:sub(r, r)
    end
    return str
end

