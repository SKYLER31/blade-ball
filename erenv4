    lbl.Position        = UDim2.new(0,14,0,6)
    lbl.BackgroundTransparency = 1
    lbl.Text            = title
    lbl.Font            = Enum.Font.GothamSemibold
    lbl.TextSize        = 13
    lbl.TextColor3      = C.TEXT
    lbl.TextXAlignment  = Enum.TextXAlignment.Left

    local selected = Flags[flag] or options[1]
    local selLbl = Instance.new("TextButton", card)
    selLbl.Size         = UDim2.new(1,-28,0,22)
    selLbl.Position     = UDim2.new(0,14,0,28)
    selLbl.BackgroundColor3 = C.ACCENT_DIM
    selLbl.Text         = "▾  " .. selected
    selLbl.Font         = Enum.Font.Gotham
    selLbl.TextSize     = 12
    selLbl.TextColor3   = C.TEXT
    selLbl.AutoButtonColor = false
    selLbl.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner",selLbl).CornerRadius = UDim.new(0,6)
    Instance.new("UIPadding",selLbl).PaddingLeft = UDim.new(0,8)

    local menu = Instance.new("Frame", card)
    menu.Size           = UDim2.new(1,0,0,0)
    menu.Position       = UDim2.new(0,0,1,4)
    menu.BackgroundColor3 = C.PANEL
    menu.BorderSizePixel= 0
    menu.ZIndex         = 10
    menu.ClipsDescendants = true
    menu.Visible        = false
    Instance.new("UICorner",menu).CornerRadius = UDim.new(0,8)
    Instance.new("UIStroke",menu).Color = C.ACCENT

    local menuList = Instance.new("UIListLayout", menu)
    menuList.Padding    = UDim.new(0,2)
    Instance.new("UIPadding",menu).PaddingTop = UDim.new(0,4)
    Instance.new("UIPadding",menu).PaddingBottom = UDim.new(0,4)

    local totalH = #options * 28 + 8
    local open = false

    for _, opt in ipairs(options) do
        local ob = Instance.new("TextButton", menu)
        ob.Size             = UDim2.new(1,-8,0,26)
        ob.Position         = UDim2.new(0,4,0,0)
        ob.BackgroundColor3 = opt == selected and C.ACCENT_DIM or C.PANEL
        ob.Text             = opt
        ob.Font             = Enum.Font.Gotham
        ob.TextSize         = 12
        ob.TextColor3       = opt == selected and C.TEXT or C.TEXT_DIM
        ob.AutoButtonColor  = false
        Instance.new("UICorner",ob).CornerRadius = UDim.new(0,6)

        ob.MouseEnter:Connect(function() tween(ob,{BackgroundColor3=C.ACCENT_DIM,TextColor3=C.TEXT},0.1) end)
        ob.MouseLeave:Connect(function()
            tween(ob,{BackgroundColor3=(Flags[flag]==opt and C.ACCENT_DIM or C.PANEL),TextColor3=(Flags[flag]==opt and C.TEXT or C.TEXT_DIM)},0.1)
        end)
        ob.MouseButton1Click:Connect(function()
            selected = opt
            if flag then Flags[flag] = opt end
            selLbl.Text = "▾  " .. opt
            if callback then callback(opt) end
            tween(menu,{Size=UDim2.new(1,0,0,0)},0.2,Enum.EasingStyle.Quint)
            task.delay(0.22,function() menu.Visible = false end)
            open = false
        end)
    end

    selLbl.MouseButton1Click:Connect(function()
        open = not open
        menu.Visible = open
        if open then
            tween(menu,{Size=UDim2.new(1,0,0,totalH)},0.2,Enum.EasingStyle.Quint)
        else
            tween(menu,{Size=UDim2.new(1,0,0,0)},0.15,Enum.EasingStyle.Quint)
            task.delay(0.2,function() if not open then menu.Visible = false end end)
        end
    end)

    return card
end

local function Slider(page, title, min, max, default, flag, callback)
    local card = Instance.new("Frame", page)
    card.Size           = UDim2.new(1,-16,0,64)
    card.BackgroundColor3 = C.CARD
    card.BorderSizePixel= 0
    Instance.new("UICorner",card).CornerRadius = UDim.new(0,10)
    Instance.new("UIStroke",card).Color = C.STROKE

    local lbl = Instance.new("TextLabel", card)
    lbl.Size            = UDim2.new(1,-60,0,20)
    lbl.Position        = UDim2.new(0,14,0,6)
    lbl.BackgroundTransparency = 1
    lbl.Text            = title
    lbl.Font            = Enum.Font.GothamSemibold
    lbl.TextSize        = 13
    lbl.TextColor3      = C.TEXT
    lbl.TextXAlignment  = Enum.TextXAlignment.Left

    local valLbl = Instance.new("TextLabel", card)
    valLbl.Size         = UDim2.new(0,50,0,20)
    valLbl.Position     = UDim2.new(1,-64,0,6)
    valLbl.BackgroundTransparency = 1
    valLbl.Font         = Enum.Font.GothamBold
    valLbl.TextSize     = 13
    valLbl.TextColor3   = C.ACCENT2
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local track = Instance.new("Frame", card)
    track.Size          = UDim2.new(1,-28,0,6)
    track.Position      = UDim2.new(0,14,0,44)
    track.BackgroundColor3 = C.TOGGLE_OFF
    track.BorderSizePixel = 0
    Instance.new("UICorner",track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame", track)
    fill.Size           = UDim2.new(0,0,1,0)
    fill.BackgroundColor3 = C.ACCENT
    fill.BorderSizePixel= 0
    Instance.new("UICorner",fill).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", track)
    knob.Size           = UDim2.fromOffset(14,14)
    knob.AnchorPoint    = Vector2.new(0.5,0.5)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel= 0
    knob.Position       = UDim2.new(0,0,0.5,0)
    Instance.new("UICorner",knob).CornerRadius = UDim.new(1,0)

    local value = default or min
    if flag then Flags[flag] = value end

    local function setValue(v)
        v = math.clamp(math.floor(v), min, max)
        value = v
        if flag then Flags[flag] = v end
        local pct = (v - min) / (max - min)
        tween(fill,{Size=UDim2.new(pct,0,1,0)},0.1)
        tween(knob,{Position=UDim2.new(pct,0,0.5,0)},0.1)
        valLbl.Text = tostring(v)
        if callback then callback(v) end
    end

    setValue(value)

    local dragging = false
    local btn = Instance.new("TextButton", card)
    btn.Size            = UDim2.new(1,0,1,0)
    btn.BackgroundTransparency = 1
    btn.Text            = ""
    btn.AutoButtonColor = false

    local function onInput(input)
        if dragging then
            local rel   = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local newV  = min + (max - min) * math.clamp(rel,0,1)
            setValue(newV)
        end
    end

    btn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            onInput(i)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(onInput)

    return setValue
end

