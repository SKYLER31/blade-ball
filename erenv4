                local ok, sp = pcall(function()
                    return cam:WorldToScreenPoint(v.PrimaryPart.Position)
                end)
                if ok then events[tostring(v)] = sp end
            end
        end
    end

    local rootPos  = char.PrimaryPart.Position
    local targetCF = predicted
        and CFrame.new(rootPos, predicted)
        or  cam.CFrame
    local pdata = {0, targetCF, events, ml}

    if Flags.AutoParryType == "Remote" then
        for remote, origArgs in pairs(ParryRemotes) do
            pcall(function()
                if remote.Name == "ParryButtonPress" or remote.Name == "Parry" then
