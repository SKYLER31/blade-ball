-- Execute parry
AP.Parry = function(ptype)
    local pdata = AP.ParryData(ptype or Flags.AutoParryDir)
    if not pdata then return end

    local hasRemote = false
    for remote, origArgs in pairs(ParryRemotes) do
        hasRemote = true
        local mArgs = {origArgs[1], origArgs[2], 0, pdata[2], pdata[3], pdata[4]}
        pcall(function()
            if remote:IsA("RemoteEvent") then
                remote:FireServer(table.unpack(mArgs))
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer(table.unpack(mArgs))
            end
        end)
    end

    if not hasRemote or Flags.AutoParryType == "Keypress" then
        -- Keypress cam manipulation
        local cam       = Camera
        local orig      = cam.CFrame
        local target    = pdata[2] * CFrame.Angles(math.rad(math.random(-4,4)), math.rad(math.random(-4,4)), 0)
        local dur       = 0.10 + math.random(-8,8)/1000
        local startT    = tick()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            local el = tick() - startT
            if el >= dur then
                conn:Disconnect()
                SimParry()
                task.delay(0.23, function()
                    local backStart = tick()
                    local backDur   = 0.12
                    local bc
                    bc = RunService.Heartbeat:Connect(function()
                        local be = tick() - backStart
                        if be >= backDur then bc:Disconnect(); return end
                        cam.CFrame = target:Lerp(orig, 1-(1-(be/backDur))^2)
                    end)
                end)
                return
            end
            cam.CFrame = orig:Lerp(target, (el/dur)^2)
        end)
    end

    if Parries < 8 then
        Parries = Parries + 1
        task.delay(0.5, function() if Parries > 0 then Parries -= 1 end end)
    end
end

