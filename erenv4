                    local root = char:FindFirstChild("HumanoidRootPart")
                    local hum  = char:FindFirstChildOfClass("Humanoid")
                    if ball and root and hum then
                        local awayDir  = (root.Position - ball.Position).Unit
                        local floor    = Workspace:FindFirstChild("FLOOR") or Workspace.Terrain
                        local targetY  = floor and (floor:IsA("BasePart") and floor.Position.Y + 5 or root.Position.Y) or root.Position.Y
                        local speed    = ball.Velocity.Magnitude
                        local gap      = 35 + math.min(speed/4, 120)
                        local dest     = root.Position + awayDir * gap
                        dest = Vector3.new(dest.X, targetY, dest.Z)
                        hum:MoveTo(dest)
                    end
                end
                task.wait(0.1)
            end
        end)
        Notify("AI Positioning", "Active", "success", 2)
    else
        AIRunning = false
        Notify("AI Positioning", "Stopped", "error", 2)
