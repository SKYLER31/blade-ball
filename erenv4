-- Ping util
local function GetPing()
    local ok, v = pcall(function()
        return game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    return ok and v or 60
end

local function GetAveragePing()
    table.insert(PingHistory, GetPing())
    if #PingHistory > 10 then table.remove(PingHistory, 1) end
    local s = 0
    for _, v in ipairs(PingHistory) do s = s + v end
    return s / #PingHistory
end

-- Ball detection
local AP = {}

AP.GetBall = function()
    local char = LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local best, bestDist = nil, math.huge
    -- Check workspace.Balls or any Part with "zoomies" LinearVelocity
    local containers = {"Balls", "Active", "Map"}
    for _, cname in ipairs(containers) do
        local cont = Workspace:FindFirstChild(cname)
        if cont then
            for _, obj in ipairs(cont:GetChildren()) do
                if obj:IsA("BasePart") and obj:FindFirstChild("zoomies") then
                    local d = (root.Position - obj.Position).Magnitude
                    if d < bestDist then bestDist = d; best = obj end
                end
            end
        end
    end
    -- Fallback: any descendant with zoomies
    if not best then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("LinearVelocity") and obj.Name == "zoomies" and obj.Parent and obj.Parent:IsA("BasePart") then
                local d = (root.Position - obj.Parent.Position).Magnitude
                if d < bestDist then bestDist = d; best = obj.Parent end
            end
        end
    end
    return best
end

-- Velocity history for curve detection
AP.VelHistory = {}
AP.DotHistory  = {}

AP.IsCurved = function(ball)
    if not Flags.CurvedDetect then return false end
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return false end
    local zoomies = ball:FindFirstChild("zoomies")
    if not zoomies then return false end

    local vel = zoomies.VectorVelocity
    local speed = vel.Magnitude
    if speed < 50 then return false end

    local dir      = (char.PrimaryPart.Position - ball.Position).Unit
    local ballDir  = vel.Unit
    local dot      = dir:Dot(ballDir)
    local dist     = (char.PrimaryPart.Position - ball.Position).Magnitude

    if not AP.VelHistory[ball] then AP.VelHistory[ball] = {} end
    if not AP.DotHistory[ball]  then AP.DotHistory[ball]  = {} end

    table.insert(AP.VelHistory[ball], vel)
    table.insert(AP.DotHistory[ball], dot)
    if #AP.VelHistory[ball] > 8  then table.remove(AP.VelHistory[ball], 1) end
    if #AP.DotHistory[ball]  > 8  then table.remove(AP.DotHistory[ball],  1) end

    -- Backwards curve
    local horizDir   = Vector3.new(dir.X, 0, dir.Z)
    local horizBall  = Vector3.new(ballDir.X, 0, ballDir.Z)
    local backCurve  = false
    if horizDir.Magnitude > 0 and horizBall.Magnitude > 0 then
        local angle = math.deg(math.acos(math.clamp((-horizDir.Unit):Dot(horizBall.Unit),-1,1)))
        backCurve   = angle < 40 and dist > 30
    end

    -- Direction change
    local dirChanged = false
    if #AP.VelHistory[ball] >= 4 then
        local prev = AP.VelHistory[ball][#AP.VelHistory[ball]-1]
        if prev.Magnitude > 100 then
            local chg = prev.Unit:Dot(vel.Unit)
            dirChanged = chg < 0.78
        end
    end

    -- Variance
    local variance, sigVar = 0, false
    if #AP.DotHistory[ball] >= 5 then
        local hist = AP.DotHistory[ball]
        for i = 2, #hist do variance = variance + math.abs(hist[i] - hist[i-1]) end
        variance = variance / (#hist - 1)
        sigVar   = variance > 0.08
    end

    local score = (dot < 0.5 and 1 or 0) + (backCurve and 3 or 0) + (dirChanged and 1 or 0) + (sigVar and 1 or 0)
    return score >= 3 or backCurve
end

-- Parry data
AP.ParryData = function(ptype)
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return nil end

    local events    = {}
    local cam       = Camera
    local mouseLoc

    if isMobile then
        mouseLoc = {cam.ViewportSize.X/2, cam.ViewportSize.Y/2}
    else
        local ml = UserInputService:GetMouseLocation()
        mouseLoc = {ml.X, ml.Y}
    end

    local aliveCont = Workspace:FindFirstChild("Alive")
    if aliveCont then
        for _, v in ipairs(aliveCont:GetChildren()) do
            if v ~= char then
                local ok, sp = pcall(function()
                    return cam:WorldToScreenPoint(v.PrimaryPart.Position)
                end)
                if ok then events[tostring(v)] = sp end
            end
        end
    end

    if ptype == "Camera" then
        return {0, cam.CFrame, events, mouseLoc}

    elseif ptype == "Backwards" then
        local v = cam.CFrame.LookVector * -10000
        v = Vector3.new(v.X, 0, v.Z)
        return {0, CFrame.new(cam.CFrame.Position, cam.CFrame.Position + v), events, mouseLoc}

    elseif ptype == "Straight" then
        local mouseVec = Vector2.new(mouseLoc[1], mouseLoc[2])
        local aimed, closest = nil, math.huge
        if aliveCont then
            for _, v in ipairs(aliveCont:GetChildren()) do
                if v ~= char then
                    local sp, onScreen = cam:WorldToScreenPoint(v.PrimaryPart.Position)
                    if onScreen then
                        local d = (mouseVec - Vector2.new(sp.X, sp.Y)).Magnitude
                        if d < closest then closest = d; aimed = v end
                    end
                end
            end
        end
        local target = aimed or Closest_Entity
        if target then
            return {0, CFrame.new(char.PrimaryPart.Position, target.PrimaryPart.Position), events, mouseLoc}
        end
        return {0, cam.CFrame, events, mouseLoc}

    elseif ptype == "High" then
        return {0, CFrame.new(cam.CFrame.Position, cam.CFrame.Position + cam.CFrame.UpVector*10000), events, mouseLoc}

    elseif ptype == "Left" then
        return {0, CFrame.new(cam.CFrame.Position, cam.CFrame.Position - cam.CFrame.RightVector*10000), events, mouseLoc}

    elseif ptype == "Right" then
        return {0, CFrame.new(cam.CFrame.Position, cam.CFrame.Position + cam.CFrame.RightVector*10000), events, mouseLoc}

    elseif ptype == "Random" then
        local dirs = {"Backwards","Left","Right","High","Camera"}
        return AP.ParryData(dirs[math.random(#dirs)])
    end

    return {0, cam.CFrame, events, mouseLoc}
end

