local IsAutoSpamming = false

AP.SpamValue = function()
    local ball = AP.GetBall()
    if not ball then return 0 end
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return 0 end
    local zoomies = ball:FindFirstChild("zoomies")
    if not zoomies then return 0 end

    local vel   = zoomies.VectorVelocity
    local speed = vel.Magnitude
    local dir   = (char.PrimaryPart.Position - ball.Position).Unit
    local dot   = dir:Dot(vel.Unit)
    local dist  = (char.PrimaryPart.Position - ball.Position).Magnitude
    local ping  = GetAveragePing()

    if dot < 0 then return 0 end  -- ball going away

    local pingAdj  = ping / 10
    local maxSpam  = pingAdj + math.min(speed/4, 200)
    if dist > maxSpam then return 0 end

    return maxSpam - math.clamp(dot,-1,0) * (5 - math.min(speed/5,5))
end

