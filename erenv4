       (self.Name:lower():find("plr") or self.Name:lower():find("input") or
        self.Name:lower():find("parr") or self.Name:lower():find("skill") or
        self.Name:lower():find("ability")) then
        local args = {...}
        -- Capture if it looks like a parry call (has CFrame argument)
        for _, v in ipairs(args) do
            if typeof(v) == "CFrame" then
                if not ParryRemotes[self] then
                    ParryRemotes[self] = args
                    Notify("Remote Captured", self:GetFullName(), "success", 3)
                else
                    ParryRemotes[self] = args
                end
                break
            end
        end
    end
    return hookedNamecall(self, ...)
end)

