Section(MiscPage, "Asset Modifications")

local OrigFace = nil
local HeadConn = nil
local KorbloxConn = nil

local function applyHeadless()
    if not Flags.Headless then return end
    local char = LocalPlayer.Character
    if not char then return end
    local head = char:WaitForChild("Head", 5)
    if not head then return end
    
    local face = head:FindFirstChild("face")
    if face and face:IsA("Decal") then OrigFace = face.Texture end
    head.Transparency = 1
    for _, c in ipairs(head:GetChildren()) do
        if c:IsA("Decal") then c:Destroy() end
    end
    
    if HeadConn then HeadConn:Disconnect() end
    HeadConn = head.ChildAdded:Connect(function(c)
        if c:IsA("Decal") then task.defer(function() c:Destroy() end) end
    end)
end

local function applyKorblox()
    if not Flags.Korblox then return end
    local char = LocalPlayer.Character
    if not char then return end
    local rLeg = char:WaitForChild("Right Leg", 5) or char:WaitForChild("RightLowerLeg", 5)
    if not rLeg then return end
    
    rLeg.Transparency = 1; rLeg.CanCollide = false
    local kPart = char:FindFirstChild("KorbloxLeg")
    if not kPart then
        kPart = Instance.new("Part", char)
        kPart.Name = "KorbloxLeg"
    end
    kPart.Size = rLeg.Size
    kPart.Anchored  = true
    kPart.CanCollide= false
    local mesh = kPart:FindFirstChildOfClass("SpecialMesh") or Instance.new("SpecialMesh", kPart)
    mesh.MeshId    = "http://www.roblox.com/asset/?id=12917863813"
    mesh.TextureId = "http://roblox.com/asset/?id=12917863954"
    mesh.Scale     = Vector3.new(1.5,1.5,1.5)
    
    if KorbloxConn then KorbloxConn:Disconnect() end
    KorbloxConn = RunService.Heartbeat:Connect(function()
        if rLeg and kPart and kPart.Parent then
            kPart.CFrame = rLeg.CFrame * CFrame.Angles(0, math.rad(180), 0) * CFrame.new(0,0.5,0)
        else
            if KorbloxConn then KorbloxConn:Disconnect(); KorbloxConn = nil end
        end
    end)
end

local function removeHeadless()
    local char = LocalPlayer.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if head then
        head.Transparency = 0
        if OrigFace then
            local d = Instance.new("Decal", head)
            d.Name    = "face"
            d.Texture = OrigFace
        end
    end
    if HeadConn then HeadConn:Disconnect(); HeadConn = nil end
end

local function removeKorblox()
    local char = LocalPlayer.Character
    if not char then return end
    local rLeg = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightLowerLeg")
    if rLeg then
        rLeg.Transparency = 0; rLeg.CanCollide = true
    end
    local kp = char:FindFirstChild("KorbloxLeg")
    if kp then kp:Destroy() end
    if KorbloxConn then KorbloxConn:Disconnect(); KorbloxConn = nil end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    if Flags.Headless then applyHeadless() end
    if Flags.Korblox then applyKorblox() end
end)

Toggle(MiscPage, "Optimize Face (Invisible Head)", "Modify localized visual components", "Headless", function(v)
    if v then applyHeadless() else removeHeadless() end
end)

Toggle(MiscPage, "Optimize Right Leg (Mesh Replace)", "Modify localized lower limb components", "Korblox", function(v)
    if v then applyKorblox() else removeKorblox() end
end)

