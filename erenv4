                phantomConn = phantom.OnClientEvent:Connect(function(_, b)
                    if b and b.Name == tostring(LocalPlayer) then
                        Phantom = true
                    else
                        Phantom = false
                    end
                end)
            end
            local db = remotes:FindFirstChild("DeathBall")
            if db and not deathConn then
                deathConn = db.OnClientEvent:Connect(function(v) DeathSlash = v end)
            end
        end
    end)
end

