--  MAIN LOOP
-- ─────────────────────────────────────────────
local LastParry   = 0
local MinDelay    = 1/5
local SpamCoroutine = nil

RunService.Heartbeat:Connect(function()
    if not (Flags.AutoParry or Flags.AutoSpam or Flags.Visualizer) then
        if VizPart and VizPart.Parent then
            VizPart.Parent = nil
        end
        return
    end

    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return end

    local ball    = AP.GetBall()
    local now     = tick()
    local ping    = GetAveragePing()

    -- Auto Parry
    if Flags.AutoParry and ball then
        local zoomies = ball:FindFirstChild("zoomies")
        if zoomies then
            local vel   = zoomies.VectorVelocity
            local speed = vel.Magnitude
            local dist  = (char.PrimaryPart.Position - ball.Position).Magnitude
            local dir   = (char.PrimaryPart.Position - ball.Position).Unit
            local dot   = dir:Dot(vel.Unit)

            local pingComp = Flags.PingCompensation and (ping / 1000) or 0
            local parryDist = math.clamp(speed * (0.05 + pingComp), 5, 60)

            local curved   = AP.IsCurved(ball)
            local ptype    = Flags.AutoParryDir

            AP.RecordBallState(ball)

            if dot > 0.4 and dist < parryDist and Parries < 8 then
                if now - LastParry >= MinDelay then
                    LastParry = now
                    if curved and Flags.AntiCurve then
                        task.spawn(function() AP.AntiCurveParry() end)
                    elseif curved then
                        task.spawn(function() AP.Parry("Camera") end)
                    else
                        task.spawn(function() AP.Parry(ptype) end)
                    end
                end
            end
        end
    end

    -- Auto Spam
    if Flags.AutoSpam then
        local sv = AP.SpamValue()
        if sv > 0 then
            if not IsAutoSpamming then
                IsAutoSpamming = true
                SpamCoroutine = task.spawn(function()
                    while Flags.AutoSpam and IsAutoSpamming do
                        if AP.SpamValue() > 0 then
                            if Flags.AutoSpamType == "Remote" then
                                AP.Parry(Flags.AutoParryDir)
                            else
                                SimParry()
                            end
                        end
                        task.wait(0.05)
                    end
                    IsAutoSpamming = false
                end)
            end
        else
            IsAutoSpamming = false
        end
    else
        IsAutoSpamming = false
    end

    -- Visualizer
    if Flags.Visualizer and ball then
        setupVisualizerPart()
        if VizPart then
            if VizPart.Parent ~= Camera then VizPart.Parent = Camera end
            local vel     = ball.Velocity.Magnitude
            local radius  = math.clamp(vel/2.4 + 10, 15, 50)
            VizPart.Size  = Vector3.new(radius, radius, radius)
            VizPart.CFrame= char.PrimaryPart.CFrame
            VizPart.Color = IsAutoSpamming and C.RED or C.ACCENT
        end
    else
        if VizPart then
            VizPart.Size = Vector3.new(0,0,0)
            VizPart.Parent = nil
        end
    end
end)

